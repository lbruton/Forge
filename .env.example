# Forge Sidecar Environment Configuration
# Copy this file to .env and set your values:
#   cp .env.example .env
#
# docker-compose reads .env automatically.

# Frontend URL — the browser origin that CORS will accept.
# For local dev: http://localhost:5173 (Vite default)
# For production: your reverse proxy URL (e.g. https://forge.example.com)
FORGE_CORS_ORIGIN=http://localhost:5173

# Vuln-cisco sidecar listen port (default: 8400)
FORGE_VULN_PORT=8400

# Scan results storage directory inside the container (default: /data/results)
DATA_DIR=/data/results
